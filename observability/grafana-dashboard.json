{
  "id": null,
  "uid": "customs-agent-dashboard",
  "title": "Customs Agent Observability",
  "tags": ["customs", "backend"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total API Requests per Minute",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate({job=\"customs-agent\"}[1m]))",
          "refId": "A",
          "legendFormat": "Requests/min"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate({job=\"customs-agent\", level=\"ERROR\"}[1m]))",
          "refId": "A",
          "legendFormat": "Errors/min"
        }
      ]
    },
    {
      "id": 3,
      "title": "Endpoint Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (endpoint) (count_over_time({job=\"customs-agent\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{endpoint}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Tracing (search by X-Request-ID)",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "{job=\"customs-agent\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true
      }
    },
    {
      "id": 5,
      "title": "Processing Time Trend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "avg_over_time({job=\"customs-agent\"} | json | __error__=\"\" | unwrap response_time [1m])",
          "refId": "A",
          "legendFormat": "Avg Processing Time (ms)"
        }
      ]
    }
  ]
}
